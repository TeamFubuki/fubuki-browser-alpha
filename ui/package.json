{
  "name": "fubuki-browser-alpha-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "format": "oxfmt src/ --write",
    "format:check": "oxfmt src/ --check"
  },
  "dependencies": {
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "oxc-resolver": "^11.24.2",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  }
}
